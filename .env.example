# API
AI_VS_HUMAN_HOST=0.0.0.0
AI_VS_HUMAN_PORT=8000
AI_VS_HUMAN_LOG_LEVEL=INFO

# Model (default paths relative to project root)
AI_VS_HUMAN_MODEL_PATH=artifacts/model.joblib
AI_VS_HUMAN_METRICS_PATH=artifacts/metrics.json

# Optional: Groq for agent explanations / multi-model fallback (leave empty to disable LLM features)
GROQ_API_KEY=
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# HTTP client defaults
AI_VS_HUMAN_HTTP_TIMEOUT_S=30.0
AI_VS_HUMAN_HTTP_MAX_RETRIES=3
